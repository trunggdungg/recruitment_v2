<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_applicant_detail" name="Chi tiết ứng viên">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>

                <div class="p-4">
                    <!-- Breadcrumb -->
                    <div class="mb-4">
                        <a href="/my/recruitment?tab=applicants" class="text-decoration-none">
                            <i class="fa fa-arrow-left me-1"></i>
                            Quay lại danh sách ứng viên
                        </a>
                    </div>

                    <!-- Header -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-header" style="background-color: #1E3769; color: #fff;">
                            <h4 class="mb-0">
                                <i class="fa fa-user me-2"></i>
                                <t t-esc="applicant.partner_name or applicant.name"/>
                            </h4>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p class="mb-2">
                                        <strong>Vị trí ứng tuyển:</strong>
                                        <span class="ms-2">
                                            <t t-esc="applicant.job_id.name"/>
                                        </span>
                                    </p>
                                    <p class="mb-2">
                                        <strong>Email:</strong>
                                        <span class="ms-2">
                                            <t t-esc="applicant.email_from or 'Chưa cung cấp'"/>
                                        </span>
                                    </p>
                                    <p class="mb-2">
                                        <strong>Số điện thoại:</strong>
                                        <span class="ms-2">
                                            <t t-esc="applicant.partner_phone or 'Chưa cung cấp'"/>
                                        </span>
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <p class="mb-2">
                                        <strong>Ngày nộp:</strong>
                                        <span class="ms-2">
                                            <t t-esc="applicant.create_date.strftime('%d/%m/%Y') if applicant.create_date else '-'"/>
                                        </span>
                                    </p>
                                    <p class="mb-2">
                                        <strong>Trạng thái hiện tại:</strong>
                                        <td>
                                                    <t t-if="applicant.recruiter_feedback == 'pending'">
                                                        <span class="badge bg-warning text-dark">Chờ xét duyệt</span>
                                                    </t>
                                                    <t t-elif="applicant.recruiter_feedback == 'approved'">
                                                        <span class="badge bg-primary">Đạt</span>
                                                    </t>
                                                    <t t-elif="applicant.recruiter_feedback == 'interview'">
                                                        <span class="badge bg-success">Phỏng vấn</span>
                                                    </t>
                                                    <t t-elif="applicant.recruiter_feedback == 'rejected'">
                                                        <span class="badge bg-danger">Không đạt</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge bg-secondary">-</span>
                                                    </t>
                                        </td>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                  <!-- ===== PIPELINE STAGE BAR ===== -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-body py-3">
                            <div class="d-flex align-items-center gap-2">

                                <div class="pipeline-bar-wrapper flex-grow-1">

                                    <a href="#"
                                       t-att-data-action="'pending'"
                                       t-attf-class="pipeline-stage-arrow #{'s-active' if applicant.recruiter_feedback == 'pending' else ('s-done' if applicant.recruiter_feedback in ['interview','approved','contracted'] else '')}">
                                        <i class="fa fa-hourglass-half me-1"></i>
                                        Chờ xét duyệt
                                    </a>

                                    <a href="#"
                                       t-att-data-action="'interview'"
                                       t-attf-class="pipeline-stage-arrow #{'s-active' if applicant.recruiter_feedback == 'interview' else ('s-done' if applicant.recruiter_feedback in ['approved','contracted'] else '')}">
                                        <i class="fa fa-calendar me-1"></i>
                                        Mời phỏng vấn

                                        <t t-if="applicant.recruiter_feedback == 'interview' and applicant.interview_date">
                                            <span class="badge ms-1" style="background:rgba(255,255,255,0.25);font-size:0.7rem;">
                                                <t t-esc="applicant.interview_date.strftime('%d/%m')"/>
                                            </span>
                                        </t>
                                    </a>

                                    <a href="#"
                                       t-att-data-action="'approved'"
                                       t-attf-class="pipeline-stage-arrow #{'s-active' if applicant.recruiter_feedback == 'approved' else ('s-done' if applicant.recruiter_feedback == 'contracted' else '')}">
                                        <i class="fa fa-thumbs-up me-1"></i>
                                        Đạt yêu cầu
                                    </a>

                                    <a href="#"
                                       t-att-data-action="'contracted'"
                                       t-attf-class="pipeline-stage-arrow #{'s-active' if applicant.recruiter_feedback == 'contracted' else ''}">
                                        <i class="fa fa-file-text me-1"></i>
                                        Hợp đồng ký 12
                                    </a>

                                </div>

                                <a href="#"
                                   t-att-data-action="'rejected'"
                                   t-attf-class="pipeline-fail-btn #{'s-active' if applicant.recruiter_feedback == 'rejected' else ''}">
                                    <i class="fa fa-times-circle me-1"></i>
                                    Fail
                                </a>

                            </div>
                        </div>
                    </div>

                    <!-- Các tab thông tin -->
                    <ul class="nav nav-tabs mb-4" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" data-bs-toggle="tab"
                                    data-bs-target="#info-tab" type="button">
                                <i class="fa fa-info-circle me-1"></i>Thông tin ứng viên
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <t t-if="applicant.recruiter_feedback == 'interview'">
                                <button class="nav-link" data-bs-toggle="tab"
                                        data-bs-target="#interview-tab" type="button">
                                    <i class="fa fa-calendar me-1"></i>Lịch phỏng vấn
                                    <t t-if="applicant.interview_date">
                                        <span class="badge bg-success ms-1">
                                            <t t-esc="applicant.interview_date.strftime('%d/%m')"/>
                                        </span>
                                    </t>
                                </button>
                            </t>
                            <t t-else="">
                                <button class="nav-link disabled" type="button"
                                        title="Cần chuyển sang 'Mời phỏng vấn' trước">
                                    <i class="fa fa-calendar me-1"></i>Lịch phỏng vấn
                                    <i class="fa fa-lock ms-1"/>
                                </button>
                            </t>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <!-- Tab: Thông tin ứng viên -->
                        <div class="tab-pane fade show active" id="info-tab">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title mb-3">Thông tin chi tiết</h5>

                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="text-muted small">Tên ứng viên</label>
                                            <p class="mb-0 fw-bold">
                                                <t t-esc="applicant.partner_name or applicant.name"/>
                                            </p>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="text-muted small">Email</label>
                                            <p class="mb-0">
                                                <t t-esc="applicant.email_from or '-'"/>
                                            </p>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="text-muted small">Số điện thoại</label>
                                            <p class="mb-0">
                                                <t t-esc="applicant.partner_phone or '-'"/>
                                            </p>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-md-12">
                                            <label class="text-muted small">Giới thiệu ngắn</label>
                                            <div class="mb-0 border rounded p-2 bg-light">
                                                <t t-if="applicant.applicant_notes">
                                                    <t t-raw="applicant.applicant_notes"/>
                                                </t>
                                                <t t-else="">-</t>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-12">
                                            <label class="text-muted small">CV đính kèm</label>
                                            <div class="p-3 bg-light rounded">
                                                <t t-if="applicant.attachment_ids">
                                                    <t t-foreach="applicant.attachment_ids" t-as="attachment">
                                                        <div class="d-flex align-items-center mb-2">
                                                            <i class="fa fa-file-pdf-o text-danger me-2"></i>
                                                            <a t-attf-href="/web/content/#{attachment.id}/#{attachment.name}"
                                                               target="_blank"
                                                               class="text-decoration-none">
                                                                <t t-esc="attachment.name"/>
                                                            </a>
                                                            <span class="text-muted ms-2">
                                                                (<t t-esc="attachment.file_size // 1024"/> KB)
                                                            </span>
                                                        </div>
                                                    </t>
                                                </t>
                                                <t t-else="">
                                                    <p class="text-muted mb-0">Không có CV đính kèm</p>
                                                </t>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Ghi chú nhà tuyển dụng -->
                                    <div class="row mb-3">
                                        <div class="col-12">
                                            <form t-attf-action="/my/recruitment/applicant/#{applicant.id}/update_note"
                                                  method="post">
                                                <input type="hidden" name="csrf_token"
                                                       t-att-value="request.csrf_token()"/>
                                                <label class="text-muted small">Ghi chú của nhà tuyển dụng</label>
                                                <textarea class="form-control" name="note" rows="3"
                                                          placeholder="Nhập ghi chú về ứng viên này..."><t t-esc="applicant.recruiter_note or ''"/></textarea>
                                                <div class="mt-2">
                                                    <button type="submit" class="btn btn-sm"
                                                            style="background-color: #1E3769; color: #fff;">
                                                        <i class="fa fa-save me-1"></i>Lưu ghi chú
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <!-- Tab: Lịch phỏng vấn -->
                        <div class="tab-pane fade" id="interview-tab">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <t t-if="applicant.recruiter_feedback != 'interview'">
                                <div class="text-center py-5 text-muted">
                                    <i class="fa fa-lock fa-3x mb-3 d-block"></i>
                                    <p class="mb-0">Cần chuyển sang <strong>"Mời phỏng vấn"</strong> trước.</p>
                                </div>
                            </t>
                            <t t-else="">

                                <!-- Alert kết quả -->
                                <t t-if="msg == 'sent'">
                                    <div class="alert alert-success alert-dismissible">
                                        <i class="fa fa-check-circle me-2"></i>
                                        <strong>Đã gửi!</strong> Email mời phỏng vấn đã được gửi thành công.
                                    </div>
                                </t>
                                <t t-elif="msg == 'error'">
                                    <div class="alert alert-danger">
                                        <i class="fa fa-exclamation-circle me-2"></i>
                                        Gửi email thất bại. Vui lòng thử lại.
                                    </div>
                                </t>
                                <t t-elif="msg == 'no_date'">
                                    <div class="alert alert-warning">
                                        <i class="fa fa-warning me-2"></i>
                                        Vui lòng chọn ngày giờ phỏng vấn.
                                    </div>
                                </t>

                                <!-- Form gửi email -->
                                <h5 class="card-title mb-3">
                                    <i class="fa fa-envelope me-2"></i>Gửi email mời phỏng vấn
                                </h5>

                                <form t-attf-action="/my/recruitment/applicant/#{applicant.id}/send_interview_email"
                                      method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label">
                                                Ngày giờ phỏng vấn <span class="text-danger">*</span>
                                            </label>
                                            <input type="datetime-local" class="form-control" name="interview_date"
                                                   required="required"
                                                   t-att-value="applicant.interview_date.strftime('%Y-%m-%dT%H:%M') if applicant.interview_date else ''"/>
                                        </div>

                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Địa điểm / Link meeting</label>
                                        <input type="text" class="form-control" name="location"
                                               placeholder="VD: Tầng 5, 123 Nguyễn Huệ  hoặc  meet.google.com/abc-xyz"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Ghi chú thêm cho ứng viên</label>
                                        <textarea class="form-control" name="extra_note" rows="3"
                                                  placeholder="Yêu cầu chuẩn bị, dress code, mang theo hồ sơ..."/>
                                    </div>

                                    <!-- Preview thông tin gửi -->
                                    <div class="alert alert-light border mb-3 py-2">
                                        <div class="small text-muted">
                                            <i class="fa fa-paper-plane me-1"></i>
                                            Gửi đến: <strong><t t-esc="applicant.email_from or 'Chưa có email'"/></strong>
                                        </div>
                                        <div class="small text-muted">
                                            <i class="fa fa-tag me-1"></i>
                                            Tiêu đề: <em>Thư mời phỏng vấn - <t t-esc="applicant.job_id.name"/></em>
                                        </div>
                                    </div>

                                    <button type="submit" class="btn"
                                            style="background-color:#1E3769;color:#fff;">
                                        <i class="fa fa-paper-plane me-1"></i>Gửi email mời phỏng vấn
                                    </button>
                                </form>

                                <!-- Lịch sử gửi email -->
                                <hr class="my-4"/>
                                <h6 class="mb-3">
                                    <i class="fa fa-history me-1 text-muted"></i>
                                    Lịch sử gửi email
                                    <t t-if="interview_email_log">
                                        <span class="badge ms-1" style="background:#1E3769;">
                                            <t t-esc="len(interview_email_log)"/>
                                        </span>
                                    </t>
                                </h6>

                                <t t-if="interview_email_log">
                                    <t t-foreach="interview_email_log" t-as="log">
                                        <div class="d-flex mb-3 align-items-start">
                                            <!-- Icon timeline -->
                                            <div class="me-3 text-center" style="min-width:36px;">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                     style="width:36px;height:36px;background:#1E3769;color:#fff;">
                                                    <i class="fa fa-envelope" style="font-size:13px;"></i>
                                                </div>
                                            </div>
                                            <!-- Card log -->
                                            <div class="flex-grow-1 border rounded p-3 bg-light">
                                                <div class="d-flex justify-content-between mb-1">
                                                    <strong class="small">Email mời phỏng vấn</strong>
                                                    <small class="text-muted">
                                                        <i class="fa fa-clock-o me-1"></i>
                                                        <t t-esc="log.get('sent_at', '-')"/>
                                                    </small>
                                                </div>
                                                <div class="small text-muted mb-1">
                                                    <i class="fa fa-calendar me-1"></i>
                                                    Lịch PV: <strong><t t-esc="log.get('interview_date', '-')"/></strong>
                                                </div>
                                                <div class="small text-muted mb-1">
                                                    <i class="fa fa-map-marker me-1"></i>
                                                    <t t-esc="log.get('location', '-')"/>
                                                </div>
                                                <div class="small text-muted">
                                                    <i class="fa fa-user me-1"></i>
                                                    Gửi bởi: <t t-esc="log.get('sent_by', '-')"/>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="text-center py-4 text-muted">
                                        <i class="fa fa-inbox fa-2x d-block mb-2"></i>
                                        <small>Chưa có email nào được gửi.</small>
                                    </div>
                                </t>

                            </t>
                        </div>
                    </div>
                </div>
            </div>

                    <!-- Toast thông báo -->
                    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
                        <div id="action-toast" class="toast" role="alert"
                             aria-live="assertive" aria-atomic="true">
                            <div class="toast-header">
                                <strong class="me-auto" id="toast-title">Thông báo</strong>
                                <button type="button" class="btn-close"
                                        onclick="document.getElementById('action-toast').classList.remove('show'); document.getElementById('action-toast').style.display='none';"
                                        aria-label="Close"/>
                            </div>
                            <div class="toast-body" id="toast-message"></div>
                        </div>
                    </div>
                </div>

                <!-- JavaScript -->
                <script>
                    // Gắn sự kiện click cho tất cả stage trong pipeline
                    document.addEventListener('DOMContentLoaded', function () {
                        document.querySelectorAll('[data-action]').forEach(function (el) {
                            el.addEventListener('click', function (e) {
                                e.preventDefault();
                                var action = this.getAttribute('data-action');
                                switchStage(action);
                            });
                        });
                    });

                    function switchStage(action) {
                        var payload = {
                            jsonrpc: '2.0',
                            method: 'call',
                            id: Math.floor(Math.random() * 1000000),
                            params: { action: action }
                        };

                        fetch('/my/recruitment/applicant/<t t-out="applicant.id"/>/action', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        })
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            var result = data.result || data;
                            if (result.success) {
                                showToast('Thành công', result.message, 'success');
                                setTimeout(function () { location.reload(); }, 1200);
                            } else {
                                showToast('Lỗi', result.error || 'Đã xảy ra lỗi', 'danger');
                            }
                        })
                        .catch(function (err) {
                            console.error(err);
                            showToast('Lỗi', 'Không thể thực hiện hành động', 'danger');
                        });
                    }

                    function showToast(title, message, type) {
                        var toastEl = document.getElementById('action-toast');
                        var toastHeader = toastEl.querySelector('.toast-header');
                        document.getElementById('toast-title').textContent = title;
                        document.getElementById('toast-message').textContent = message;
                        toastHeader.className = 'toast-header text-white bg-' + (type || 'primary');
                        toastEl.classList.add('show');
                        toastEl.style.display = 'block';
                        setTimeout(function () {
                            toastEl.classList.remove('show');
                            toastEl.style.display = 'none';
                        }, 3000);
                    }
                </script>
            </t>
        </template>
    </data>
</odoo>