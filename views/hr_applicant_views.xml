<!--Trường cho chi tiết đơn ứng tuyển của ứng viên cho admin xem-->
<odoo>
    <record id="view_hr_applicant_recruiter_inherit" model="ir.ui.view">
        <field name="name">hr.applicant.form.recruiter.inherit</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">

            <!-- Thêm vào nhóm bên phải, sau field "job_id" -->
            <field name="job_id" position="after">
                <field name="recruiter_feedback"
                       widget="badge"
                       decoration-warning="recruiter_feedback == 'pending'"
                       decoration-info="recruiter_feedback == 'interview'"
                       decoration-success="recruiter_feedback == 'approved' or recruiter_feedback == 'contracted'"
                       decoration-danger="recruiter_feedback == 'rejected'"
                       readonly="1"/>
            </field>

            <!-- Thêm nhà tuyển dụng là ai (lấy từ job_id.recruiter_id) -->
            <field name="job_id" position="after">
                <field name="recruiter_partner_id"
                       string="Nhà tuyển dụng"
                       readonly="1"/>
            </field>

        </field>
    </record>
</odoo>