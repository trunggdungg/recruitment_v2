<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="index" name="Jobs Custom" inherit_id="website_hr_recruitment.index">
        <!-- Lấy toàn bộ nội dung bên trong và thay thế -->
        <xpath expr="//t[@t-call='website.layout']" position="replace">
            <t t-call="website.layout">
                <div id="wrap" class="o_website_hr_recruitment_jobs_list">

                    <div class="oe_structure" id="oe_structure_hr_recruitment_index_top"/>

                    <div class="container oe_website_jobs">
                        <section
                                class="o_wevent_index_topbar_filters d-flex d-print-none align-items-center justify-content-lg-end flex-wrap gap-2 mt-4 mb-3">
                            <h1 class="me-auto mb-0 h4">Our Job Offers</h1>
                            <t t-call="website_hr_recruitment.topbar_customizations"/>
                        </section>

                        <div class="row pb16">
                            <div class="d-none" id="jobs_grid_left"/>
                            <div class="col-lg" id="jobs_grid">
                                <div class="row">
                                    <t t-if="not jobs">
                                        <div class="col">
                                            <div t-if="search" class="alert alert-warning text-center" role="alert">
                                                No results found for '<span t-out="search"/>'.
                                            </div>
                                            <div class="alert alert-info text-center text-muted"
                                                 groups="hr_recruitment.group_hr_recruitment_manager">
                                                Create new job pages from the
                                                <strong>+
                                                    <i>New</i>
                                                </strong>
                                                top-right button.
                                            </div>
                                            <div class="col-lg-12 text-center pt24">
                                                <p class="h5 fw-light text-muted pb24">
                                                    There are currently no open job opportunities,
                                                    <br class="mb-2"/>
                                                    but feel free to <span class="fw-bold">contact us</span> for a
                                                    spontaneous application.
                                                </p>
                                                <img class="img-fluid o_we_custom_image pb24"
                                                     src="/website_hr_recruitment/static/src/img/job_not_found.svg"
                                                     style="width: 50% !important;" alt="Job not found"/>
                                            </div>
                                        </div>
                                    </t>
                                    <t t-elif="search and original_search">
                                        <div class="col">
                                            <div class="alert alert-info text-center" role="alert">
                                                No results found for '<span t-out="original_search"/>'. Showing results
                                                for '<span t-out="search"/>'.
                                                <t t-set="search" t-value="original_search"/>
                                            </div>
                                        </div>
                                    </t>

                                    <div t-foreach="jobs" t-as="job" class="col-12 col-md-6 col-lg-4 mb-3">
                                        <div t-attf-class="o_job_card #{not job.website_published and 'o_jobs_unpublished' or ''}">
                                            <a t-attf-href="/recruitment/detail/#{job.id}" draggable="false">
                                                <div class="card-body">

                                                    <!-- Logo + Tên job -->
                                                    <div class="d-flex align-items-start gap-2">
                                                        <div class="wrap_o_job_logo">
                                                            <div class="o_job_logo">
                                                                <img t-if="job.hr_job_photo"
                                                                     t-att-src="'/web/image/hr.job/%s/hr_job_photo' % job.id"
                                                                     alt="Job Image"/>


                                                                        <img t-elif="job.user_id and job.user_id.partner_id.avatar_128"
                                                                             t-att-src="'/web/image/res.partner/%s/avatar_128' % job.user_id.partner_id.id"
                                                                             alt="Recruiter Avatar"/>

                                                                <t t-else="">
                                                                    <t t-out="(job.name or 'JO')[:2].upper()"/>
                                                                </t>
                                                            </div>
                                                        </div>
                                                        <div style="flex:1; min-width:0;">
                                                            <span t-if="not job.website_published"
                                                                  class="badge text-bg-danger mb-1 d-block"
                                                                  style="width:fit-content;">unpublished
                                                            </span>
                                                            <div class="o_job_title" t-out="job.name"/>
                                                            <div class="o_job_company" t-if="job.company_id"
                                                                 t-out="job.company_id.name"/>
                                                        </div>
                                                    </div>

                                                    <!-- Tags -->
                                                    <div class="o_job_tags">
                                                        <span t-if="job.no_of_recruitment >= 1" class="o_job_tag">
                                                            <t t-out="job.no_of_recruitment"/>
                                                            vị trí
                                                        </span>
                                                        <span t-if="job.state_id" class="o_job_tag">
                                                            <i class="fa fa-map-marker me-1"/>
                                                            <t t-out="job.state_id.name"/>
<!--                                                            <t t-if="job.ward_id">-->
<!--                                                                <span class="text-muted"> - <t t-esc="job.ward_id.name"/></span>-->
<!--                                                            </t>-->
                                                        </span>
                                                        <span t-else="" class="o_job_tag">
                                                            Remote
                                                        </span>
                                                        <span t-if="job.contract_type_id" class="o_job_tag">
                                                            <t t-out="job.contract_type_id.name"/>
                                                        </span>
<!--                                                        <span t-if="job.department_id" class="o_job_tag">-->
<!--                                                            <t t-out="job.department_id.name"/>-->
<!--                                                        </span>-->
                                                        <span t-if="job.salary_level_id" class="o_job_tag">
                                                            <i class="fa fa-money me-1"/>
                                                            <t t-out="job.salary_level_id.name"/>
                                                        </span>
                                                    </div>

                                                </div>
                                            </a>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <div class="navbar mb-3 w-100">
                                <t t-call="website.pager">
                                    <t t-set="classname" t-valuef="mx-auto"/>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="oe_structure" id="oe_structure_hr_recruitment_index_bottom"/>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
